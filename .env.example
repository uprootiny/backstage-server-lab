# Copy to .env and adjust for your environment
MLFLOW_TRACKING_URI=http://127.0.0.1:1111
LAB_ROOT=$(pwd)
SYNC_DEST=user@host:/path/to/backups/backstage-server-lab-artifacts

# Repo observability (Grafana + Prometheus + GitHub exporter)
GITHUB_REPOSITORY=uprootiny/backstage-server-lab
GITHUB_TOKEN=
GITHUB_EXPORTER_POLL_SECONDS=90
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Optional public/tunnel URLs for endpoint probing
MLFLOW_PUBLIC_URL=
TENSORBOARD_PUBLIC_URL=
JUPYTER_PUBLIC_URL=
KAGGLE_MASHUP_PUBLIC_URL=
RNA_BRIDGE_PUBLIC_URL=
EXTRA_ENDPOINTS=
