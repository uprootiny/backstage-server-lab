{
  "title": "RNA Observatory Operations",
  "uid": "rna-observatory-ops",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "GPU Utilization %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "targets": [{"expr": "rna_gpu_util_percent"}]
    },
    {
      "id": 2,
      "title": "VRAM Used (bytes)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "targets": [{"expr": "rna_vram_used_bytes"}]
    },
    {
      "id": 3,
      "title": "Job Status Totals",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "targets": [{"expr": "sum by (status) (increase(rna_jobs_total[1h]))"}]
    },
    {
      "id": 4,
      "title": "Dispatch Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{"expr": "rate(rna_dispatch_total[5m])"}]
    },
    {
      "id": 5,
      "title": "Rerun Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "rate(rna_rerun_total[5m])"}]
    },
    {
      "id": 6,
      "title": "CI Pass Ratio",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum(increase(rna_ci_runs_total{status=\"pass\"}[1d])) / clamp_min(sum(increase(rna_ci_runs_total[1d])),1)"
        }
      ]
    },
    {
      "id": 7,
      "title": "Deploy Success Ratio (Vast)",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 16},
      "targets": [
        {
          "expr": "sum(increase(rna_deploy_total{target=\"vast\",status=\"pass\"}[1d])) / clamp_min(sum(increase(rna_deploy_total{target=\"vast\"}[1d])),1)"
        }
      ]
    },
    {
      "id": 8,
      "title": "Operator Events by Kind",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 16},
      "targets": [{"expr": "sum by (kind) (increase(rna_operator_events_total[1h]))"}]
    }
  ]
}
